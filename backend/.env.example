# Copy to .env and adjust. All values are optional; defaults live in config.py.

# --- Models (Ollama) -------------------------------------------------------
OLLAMA_MODEL=gemma4:12b
OLLAMA_VISION_MODEL=qwen3.5:9b
OLLAMA_VISION_ENABLED=true
OLLAMA_VISION_NUM_CTX=8192
OLLAMA_DEFAULT_NUM_CTX=8192
OLLAMA_CLASSIFIER_NUM_CTX=4096
OLLAMA_GATEWAY_NUM_CTX=4096
OLLAMA_SYNTHESIS_NUM_CTX=16384
OLLAMA_CODE_NUM_CTX=32768
OLLAMA_BASE_URL=http://localhost:11434
# Ollama is the zero-config local runtime. LM Studio/llama.cpp are configured in
# the settings UI (examples: http://127.0.0.1:1234/v1 and :8080/v1); their
# optional key is stored masked in backend/data/model_settings.json.

# --- Answering backend (local-first; optional OpenAI-compatible path) -------
# Which backend serves the model-driven answering/decision calls (classify,
# tool-decision loop, expert consults, final synthesis). "ollama" keeps
# everything local (default); "openai" routes those calls to an OpenAI-compatible
# API while perception/vision and memory embeddings stay local. The runner can
# override this per run with --backend.
PILOT_ANSWER_BACKEND=ollama
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Model settings (runtime, per-role) --------------------------------------
# The settings page (⚙ in the UI, or PUT /api/settings/models) persists
# providers and per-role model assignments to this file. It OVERRIDES the env
# defaults above per role — delete the file to restore stock env behaviour.
# MODEL_SETTINGS_FILE=backend/data/model_settings.json

# --- Network / auth --------------------------------------------------------
# Loopback by default. Set to 0.0.0.0 only behind a private network (e.g.
# Tailscale) AND with the auth tokens below set. Enforced: a non-loopback host
# with an empty token is downgraded to 127.0.0.1 with a warning.
# BACKEND_HOST=127.0.0.1
# MCP_HOST=127.0.0.1
# BACKEND_PORT=8000
# MCP_PORT=3001
# Shared secret for the WebSocket hello; empty = no auth.
# PILOT_AUTH_TOKEN=
# Shared secret for the MCP endpoints; defaults to PILOT_AUTH_TOKEN.
# PILOT_MCP_AUTH_TOKEN=
# Comma-separated CORS allowlist for the main app.
# PILOT_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Web retrieval (search provider) ---------------------------------------
# Retrieval is the eval's weakest link. By default web_search/web_research
# scrape DuckDuckGo (zero-config, no key). For resilient results set a JSON
# provider + key and calls route through its API instead; with no key we fall
# back to the DuckDuckGo scraper automatically. Supported: "duckduckgo"
# (default), "tavily", "brave". Any other name works with an explicit base URL
# pointing at a Tavily-shaped API.
# PILOT_SEARCH_PROVIDER=duckduckgo
# PILOT_SEARCH_API_KEY=
# Override the provider's default endpoint (self-hosted / compatible services).
# PILOT_SEARCH_BASE_URL=
# Network retries + back-off (seconds) around search/fetch calls.
# PILOT_HTTP_RETRIES=2
# PILOT_HTTP_RETRY_DELAY=0.5

# --- Code agents -----------------------------------------------------------
# CODEX_SANDBOX_MODE=workspace-write
# CODEX_APPROVAL_POLICY=never

# --- ComfyUI image generation (optional) -----------------------------------
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# Path to your local ComfyUI checkout.
# COMFYUI_DIR=/path/to/ComfyUI
# COMFYUI_CHECKPOINT=
# COMFYUI_OUTPUT_DIR=

# --- Agent loop ------------------------------------------------------------
# MAX_AGENT_STEPS=50
# Wall-clock bound (seconds) for a single run_command; a hanging/slow command is
# killed and its partial output returned with a timeout note.
# COMMAND_TIMEOUT_SECONDS=60
# Wall-clock bound (seconds) for one whole WebSocket turn; a stalled turn (hung
# model call, stuck external agent) is cancelled and the client notified instead
# of spinning forever. 0 = disabled.
# WS_TURN_TIMEOUT_SECONDS=300

# --- Storage caps (bounded growth) -----------------------------------------
# Keep at most this many of the most recent messages when persisting a session
# (the live turn still uses the full in-memory conversation). 0 = unbounded.
# MAX_PERSISTED_MESSAGES=200
# Roll data/turn_diagnostics.jsonl to a single .1 backup once it exceeds this
# many bytes (bounds on-disk use to ~2x). 0 = no rotation.
# DIAGNOSTICS_MAX_BYTES=5242880
# Best-effort prune (on save) of session files untouched for this many days.
# 0 = never prune.
# SESSIONS_MAX_AGE_DAYS=90
