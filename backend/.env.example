# Copy to .env and adjust. All values are optional; defaults live in config.py.

# --- Models (Ollama) -------------------------------------------------------
OLLAMA_MODEL=gemma4:12b
OLLAMA_VISION_MODEL=qwen3.5:9b
OLLAMA_VISION_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434

# --- Network / auth --------------------------------------------------------
# Loopback by default. Set to 0.0.0.0 only behind a private network (e.g.
# Tailscale) AND with the auth tokens below set.
# BACKEND_HOST=127.0.0.1
# MCP_HOST=127.0.0.1
# BACKEND_PORT=8000
# MCP_PORT=3001
# Shared secret for the WebSocket hello; empty = no auth.
# PILOT_AUTH_TOKEN=
# Shared secret for the MCP endpoints; defaults to PILOT_AUTH_TOKEN.
# PILOT_MCP_AUTH_TOKEN=
# Comma-separated CORS allowlist for the main app.
# PILOT_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Code agents -----------------------------------------------------------
# CODEX_SANDBOX_MODE=workspace-write
# CODEX_APPROVAL_POLICY=never

# --- ComfyUI image generation (optional) -----------------------------------
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# Path to your local ComfyUI checkout.
# COMFYUI_DIR=/path/to/ComfyUI
# COMFYUI_CHECKPOINT=
# COMFYUI_OUTPUT_DIR=

# --- Agent loop ------------------------------------------------------------
# MAX_AGENT_STEPS=20
